print("Bienvenido a su cajero automático de confianza")
saldo = 50000
intentos = 0
while intentos < 3:
    entrada = input("\nIngrese su PIN para acceder (o escriba 'salir' para finalizar): ")
    intentos += 1 
    if entrada.lower() == "salir":
        print("Gracias por usar nuestro cajero automático, hasta luego.")
        break     
    elif entrada == "1234":
        print("\nPIN correcto, accediendo a su cuenta...")
        print(f"Su saldo actual es: ${saldo}")
        
        respuesta = input("¿Desea realizar un retiro? (si/no): ")
        if respuesta.lower() == "si":
            monto = int(input("Ingrese el monto a retirar: "))
            if monto > saldo:
                print("Fondos insuficientes, no se puede realizar la transacción.")
            elif monto <= 0:
                print("Monto inválido. Debe ser mayor a 0.")
            else:
                saldo -= monto
                print("Retiro exitoso. Por favor, retire su dinero.")
                print(f"Su nuevo saldo es: ${saldo}")
                print("Gracias por usar nuestro cajero automático.")
        else:
            print("Operación cancelada. Gracias por preferirnos.")   
        break 
        print(f"PIN incorrecto. Te quedan {3 - intentos} intentos.")

if intentos >= 3:
    print("\nHas excedido el número de intentos, tu cuenta ha sido bloqueada por seguridad.")
